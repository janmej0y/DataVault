APP_NAME=DataVault
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@datavault.test"
MAIL_FROM_NAME="${APP_NAME}"

DB_CONNECTION=mongodb
DB_DATABASE=datavault
DB_AUTHENTICATION_DATABASE=admin

# Local MongoDB setup
DB_URI=
DB_HOST=127.0.0.1
DB_PORT=27017
DB_USERNAME=
DB_PASSWORD=

# MongoDB Atlas setup (optional)
# If you use Atlas, paste the connection string into DB_URI and keep DB_DATABASE=datavault.
# Example:
# DB_URI="mongodb+srv://<username>:<urlencoded-password>@<cluster-host>/datavault?retryWrites=true&w=majority&appName=DataVault"
